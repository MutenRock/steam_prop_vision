{
  "version": 1,
  "rules": [
    {
      "when": "presence",
      "cooldown_s": 3.0,
      "then": [
        {
          "type": "udp",
          "msg": "LOXONE:PRESENCE=1"
        }
      ]
    },
    {
      "when": "PLAQUE:plaque_A",
      "require_presence": true,
      "cooldown_s": 2.0,
      "then": [
        {
          "type": "udp",
          "msg": "LOXONE:PLAQUE=A"
        },
        {
          "type": "udp",
          "msg": "CMD:START"
        }
      ]
    },
    {
      "when": "PLAQUE:plaque_B",
      "require_presence": true,
      "cooldown_s": 2.0,
      "then": [
        {
          "type": "udp",
          "msg": "LOXONE:PLAQUE=B"
        },
        {
          "type": "udp",
          "msg": "CMD:RESET"
        }
      ]
    }
  ]
}